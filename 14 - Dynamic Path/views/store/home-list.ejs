<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
      <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
        Here are our registered homes:
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% registeredHomes.forEach(home => { %>
          <div class="bg-white rounded-lg shadow-md hover:shadow-xl transition duration-300 overflow-hidden">
            <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>" class="w-full h-48 object-cover">
            <div class="p-5">
              <h3 class="text-xl font-bold text-gray-800 mb-2"><%= home.houseName %></h3>
              <p class="text-gray-600 text-sm mb-3"><i class="fas fa-map-marker-alt"></i> <%= home.location %></p>
              <div class="flex justify-between items-center mb-3">
                <span class="text-2xl font-bold text-green-600">Rs. <%= home.price %></span>
                <span class="bg-yellow-400 text-white px-3 py-1 rounded-full text-sm font-semibold">★ <%= home.rating %>/5</span>
              </div>
            </div>
            <a href="/homes/<%= home.id %>" class="bg-blue-400 p-2">Details</a>
            <button class="bg-green-400 p-2">Book</button>
            <div class="mt-2">
                    <%- include('../partials/favourite', {home: home}) %>
                  </div>
          </div>
        <% }) %>
      </div>
    </main>
  </body>
</html>